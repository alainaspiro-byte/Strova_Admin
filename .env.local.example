# API Configuration (sin barra final)
NEXT_PUBLIC_API_URL=https://unequivocally-shrinelike-zara.ngrok-free.dev/api

# Si "Failed to fetch" con ngrok: por defecto se envía ngrok-skip-browser-warning (el backend debe listarlo en CORS AllowHeaders). Si empeora, prueba: NEXT_PUBLIC_NGROK_SKIP_BROWSER_WARNING=false

# NEXT_PUBLIC_AUTH_LOGIN_PATH=/account/login
# NEXT_PUBLIC_LOGIN_BODY_PASCALCASE=true

# El login devuelve JWT en headers Authorization y RefreshToken: el backend debe incluir Access-Control-Expose-Headers: Authorization, RefreshToken y Allow-Origin con tu origen (p. ej. http://localhost:3001).

# Deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
