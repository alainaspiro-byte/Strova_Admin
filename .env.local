# API Configuration
NEXT_PUBLIC_API_URL=https://api.tucuadre.com/api

# Deployment
NEXT_PUBLIC_APP_URL=https://api.tucuadre.com/api

# Tesoreria: 'true' usa el mock en memoria (localStorage). Cambiar a 'false'
# (o quitar la variable) cuando el backend exponga /treasury/* en NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_TREASURY_MOCK=true
